# Owlka website environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.

# ── Resend (waitlist email) ────────────────────────────────────────────
# Existing integration; ask Tim for the production key.
RESEND_API_KEY=re_xxx_replace_me

# ── Stripe (Owlka Pro subscription) ────────────────────────────────────
# Use TEST keys (sk_test_…, pk_test_…) until the morning of App Store
# submission, then swap to LIVE (sk_live_…, pk_live_…).
STRIPE_SECRET_KEY=sk_test_xxx_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_xxx_replace_me

# Webhook signing secret from
# Stripe Dashboard → Developers → Webhooks → your endpoint.
# [WARNING] Do NOT configure this webhook endpoint in the Stripe Dashboard
# until master voucher-key rotation flow exists. The current handler
# provisions vouchers on checkout.session.completed but still silently
# acks customer.subscription.deleted and invoice.payment_failed — wiring
# it live before the rotation/dunning PRs ship will swallow dunning and
# cancellations with no retry.
STRIPE_WEBHOOK_SECRET=whsec_xxx_replace_me

# Price ID for the "Owlka Pro — £5/month" recurring product.
# Create the product in Stripe Dashboard → Products, then copy the
# `price_…` ID of its monthly price.
STRIPE_PRO_PRICE_ID=price_xxx_replace_me

# ── Voucher recorder (Mac Mini conv-server) ────────────────────────────
# The Stripe webhook handler POSTs each new voucher to the conv-server,
# which appends a {hash, tenant_id, status} record to the private
# owlka-vouchers ledger. The plaintext voucher never reaches the Mac Mini.
# Token must match the value in the conv-server launchd plist; rotating
# it requires updating both sides.
VOUCHER_RECORDER_URL=https://conv.owlka.com/internal/voucher-record
VOUCHER_RECORDER_TOKEN=replace_me_with_a_dedicated_secret

# From-address for the voucher email. Defaults to noreply@owlka.com.
# Must be a verified Resend sender on the owlka.com domain.
VOUCHER_FROM_EMAIL=Owlka <noreply@owlka.com>

# ── Site URL ──────────────────────────────────────────────────────────
# Used for Stripe Checkout success/cancel redirects when no Origin
# header is present (e.g. server-to-server). Defaults to owlka.com.
NEXT_PUBLIC_SITE_URL=https://owlka.com
