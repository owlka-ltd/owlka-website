# Owlka website environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is on the ignore list, never save real keys here.

# ── Site URL ──────────────────────────────────────────────────────────
# Used for canonical URLs and the OG image route. Defaults to owlka.com.
NEXT_PUBLIC_SITE_URL=https://owlka.com
