# Owlka website environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is on the ignore list, never save real keys here.

# ── Site URL ──────────────────────────────────────────────────────────
# Used for canonical URLs and the OG image route. Defaults to owlka.com.
NEXT_PUBLIC_SITE_URL=https://owlka.com

# ── Waitlist (S19) ────────────────────────────────────────────────────
# Google Apps Script web-app URL that appends each waitlist signup to
# the Google Sheet. See docs/S19-WAITLIST-INSTRUCTIONS-FOR-TIM.md for
# the one-time setup. If unset, /api/waitlist no-ops with 200 ok so a
# deploy without the secret still functions.
WAITLIST_SHEET_WEBHOOK=
